---
import AppWrapper from '../../building-blocks/AppWrapper.astro';
import PageHeader from '../../components/PageHeader.astro';
import ProjectShowcase from '../../components/ProjectShowcase.astro';
import { siteConfig } from '../../config/site';
import { getProjectsWithVersions } from '../../config/projects';

const projects = await getProjectsWithVersions();
---

<AppWrapper title={`Projects - ${siteConfig.title}`} description="Interactive projects and experiments.">
	<PageHeader
		title="Projects"
		subtitle="Open source libraries, published and maintained."
	/>

	<section class="flex flex-col gap-16 md:gap-20 pt-10 md:pt-14 max-w-3xl mx-auto">
		{projects.map((project) => (
			<ProjectShowcase
				title={project.title}
				description={project.description}
				href={project.href}
				tags={project.tags}
				status={project.status}
				logo={project.logo}
			/>
		))}
	</section>
</AppWrapper>
