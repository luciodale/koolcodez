---
import AppWrapper from '../../building-blocks/AppWrapper.astro';
import PageHeader from '../../components/PageHeader.astro';
import ProjectShowcase from '../../components/ProjectShowcase.astro';
import { siteConfig } from '../../config/site';
import { getProjectsWithVersions } from '../../config/projects';

const projects = await getProjectsWithVersions();
---

<AppWrapper
	title={`Projects | React and TypeScript libraries by ${siteConfig.author}`}
	description="Open source React and TypeScript libraries: type safe WebSocket hooks, virtualized searchable dropdowns, gesture driven sidebars, and Clojure form tooling."
	breadcrumbs={[
		{ name: 'Home', url: siteConfig.url },
		{ name: 'Projects', url: `${siteConfig.url}/projects` },
	]}
>
	<PageHeader
		title="Projects"
		subtitle="Open source libraries, published and maintained."
	/>

	<section class="flex flex-col gap-16 md:gap-20 pt-10 md:pt-14 max-w-3xl mx-auto">
		{projects.map((project) => (
			<ProjectShowcase
				title={project.title}
				description={project.description}
				href={project.href}
				tags={project.tags}
				status={project.status}
				logo={project.logo}
			/>
		))}
	</section>
</AppWrapper>
