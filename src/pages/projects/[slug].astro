---
import AppWrapper from '../../building-blocks/AppWrapper.astro';
import PageHeader from '../../components/PageHeader.astro';
import {
	fetchVersion,
	projects,
	type ProjectWithStatus,
} from '../../config/projects';
import { siteConfig } from '../../config/site';

export async function getStaticPaths() {
	const results = await Promise.all(
		projects.map(async (project) => {
			const version = await fetchVersion(project.registry, project.packageName);
			return {
				params: { slug: project.slug },
				props: { ...project, status: `${project.registry} v${version}` },
			};
		}),
	);
	return results;
}

type Props = ProjectWithStatus;

const project = Astro.props;

const installCommand =
	project.registry === 'npm'
		? `npm install ${project.packageName}`
		: `;; deps.edn
{:deps {${project.packageName}/${project.packageName} {:mvn/version "${project.status.replace('clojars v', '')}"}}}`;

const canonicalUrl = new URL(`/projects/${project.slug}`, siteConfig.url).toString();
const logoUrl = new URL(project.logo, siteConfig.url).toString();

const softwareLd = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: project.packageName,
	alternateName: project.title,
	description: project.description,
	url: canonicalUrl,
	image: logoUrl,
	applicationCategory: project.applicationCategory,
	operatingSystem: 'Cross platform',
	keywords: project.keywords.join(', '),
	softwareVersion: project.status.replace(`${project.registry} v`, ''),
	license: `https://opensource.org/licenses/${project.license}`,
	author: {
		'@type': 'Person',
		name: siteConfig.author,
		url: siteConfig.url,
		sameAs: [siteConfig.social.github, siteConfig.social.linkedin],
	},
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'USD',
	},
};

const sourceCodeLd = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareSourceCode',
	name: project.packageName,
	description: project.description,
	codeRepository: project.repoUrl,
	programmingLanguage: project.programmingLanguage,
	url: canonicalUrl,
	license: `https://opensource.org/licenses/${project.license}`,
	author: {
		'@type': 'Person',
		name: siteConfig.author,
		url: siteConfig.url,
	},
	keywords: project.keywords.join(', '),
};

const softwareLdJson = JSON.stringify(softwareLd);
const sourceCodeLdJson = JSON.stringify(sourceCodeLd);

const packageLink =
	project.registry === 'npm'
		? `https://www.npmjs.com/package/${project.packageName}`
		: `https://clojars.org/${project.packageName}`;

const otherProjects = projects.filter((p) => p.slug !== project.slug);
---

<AppWrapper
	title={`${project.title} | ${project.shortDescription}`}
	description={project.description}
	ogImage={`/og-${project.slug}.png`}
	breadcrumbs={[
		{ name: 'Home', url: siteConfig.url },
		{ name: 'Projects', url: `${siteConfig.url}/projects` },
		{ name: project.title, url: canonicalUrl },
	]}
>
	<script type="application/ld+json" set:html={softwareLdJson} is:inline />
	<script type="application/ld+json" set:html={sourceCodeLdJson} is:inline />

	<PageHeader title={project.title} subtitle={project.shortDescription} />

	<section class="max-w-3xl mx-auto pt-10 md:pt-14 flex flex-col gap-10">
		<div class="flex items-center gap-4">
			<img src={project.logo} alt={`${project.title} logo`} class="w-14 h-14" />
			<div class="flex flex-col gap-1">
				<div class="text-sm font-family-mono text-white/50">{project.status}</div>
				<div class="font-family-mono text-sm text-white/80">{project.packageName}</div>
			</div>
		</div>

		<p class="text-lg font-light text-white/80 leading-relaxed">
			{project.description}
		</p>

		<div class="flex flex-wrap gap-2">
			{project.tags.map((tag) => (
				<span class="px-2.5 py-1 text-xs font-family-mono text-white/60 bg-white/[0.03] rounded border border-white/[0.06]">
					{tag}
				</span>
			))}
		</div>

		<div class="flex flex-col gap-3">
			<h2 class="text-xl font-light text-white">Install</h2>
			<pre class="bg-white/5 border border-white/10 rounded-lg p-4 overflow-x-auto text-sm font-family-mono text-white/90"><code>{installCommand}</code></pre>
		</div>

		<div class="flex flex-wrap gap-4">
			<a
				href={packageLink}
				target="_blank"
				rel="noopener noreferrer"
				class="px-4 py-2 border border-white/20 rounded text-white/90 hover:border-accent hover:text-accent transition-colors duration-200 text-sm"
			>
				View on {project.registry === 'npm' ? 'npm' : 'Clojars'} &rarr;
			</a>
			<a
				href={project.repoUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="px-4 py-2 border border-white/20 rounded text-white/90 hover:border-accent hover:text-accent transition-colors duration-200 text-sm"
			>
				View source on GitHub &rarr;
			</a>
		</div>

		<div class="flex flex-col gap-3">
			<h2 class="text-xl font-light text-white">Keywords</h2>
			<div class="flex flex-wrap gap-2">
				{project.keywords.map((keyword) => (
					<span class="px-2 py-0.5 text-xs font-family-mono text-white/50 bg-white/[0.03] rounded border border-white/[0.06]">
						{keyword}
					</span>
				))}
			</div>
		</div>

		<div class="flex flex-col gap-4 pt-8 border-t border-white/10">
			<h2 class="text-xl font-light text-white">Other projects</h2>
			<div class="flex flex-col gap-3">
				{otherProjects.map((other) => (
					<a
						href={other.href}
						class="text-sm text-white/70 hover:text-accent transition-colors duration-200"
					>
						<span class="font-family-mono">{other.title}</span>
						<span class="text-white/40"> — {other.shortDescription}</span>
					</a>
				))}
			</div>
		</div>
	</section>
</AppWrapper>
