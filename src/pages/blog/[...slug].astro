---
import { Image } from 'astro:assets';
import { type CollectionEntry, getCollection, render } from 'astro:content';
import AppWrapper from '../../building-blocks/AppWrapper.astro';
import { projects } from '../../config/projects';
import { siteConfig } from '../../config/site';
import { formatDate } from '../../utils';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

const haystack =
	`${post.data.title} ${post.data.description}`.toLowerCase();
const relatedProjects = projects.filter((project) => {
	const terms = [project.title, ...project.tags, ...project.keywords];
	return terms.some((term) => haystack.includes(term.toLowerCase()));
});

const allPosts = (await getCollection('blog'))
	.filter((p) => p.id !== post.id)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<AppWrapper
	title={`${post.data.title} - ${siteConfig.title}`}
	description={post.data.description}
	ogImage={post.data.heroImage ? new URL(post.data.heroImage.src, siteConfig.url).href : undefined}
	ogType="article"
	publishedTime={post.data.pubDate.toISOString()}
	modifiedTime={post.data.updatedDate?.toISOString()}
	author={siteConfig.author}
	breadcrumbs={[
		{ name: 'Home', url: siteConfig.url },
		{ name: 'Blog', url: `${siteConfig.url}/blog` },
		{ name: post.data.title, url: `${siteConfig.url}/blog/${post.id}` },
	]}
>
	<article class="w-full md:max-w-4xl mx-auto md:px-6 py-8 md:py-16">
		<header class="mb-8 md:mb-12">
			{post.data.heroImage && (
				<div class="mb-6 md:mb-8 rounded-lg overflow-hidden flex justify-center">
					<Image
						src={post.data.heroImage}
						width={800}
						alt={`${post.data.title} - ${post.data.description}`}
						class="h-80 md:h-96 object-cover"
					/>
				</div>
			)}
			<div class="prose prose-invert mx-auto">
			<h1 class="text-2xl md:text-4xl font-bold mb-3 md:mb-4 leading-tight">{post.data.title}</h1>
			<p class="text-lg md:text-xl text-white/70 mb-3 md:mb-4 leading-relaxed">{post.data.description}</p>
			<time class="text-sm text-white/50 font-mono block">
				{formatDate(post.data.pubDate)}
			</time>
			</div>
		</header>
		
		<div class="prose prose-invert overflow-hidden mx-auto">
			<Content />
		</div>

		{relatedProjects.length > 0 && (
			<aside class="prose prose-invert mx-auto mt-16 pt-8 border-t border-white/10">
				<h2 class="text-xl font-light text-white !mt-0">Related libraries</h2>
				<ul class="list-none pl-0">
					{relatedProjects.map((project) => (
						<li class="pl-0">
							<a href={project.href} class="no-underline hover:text-accent">
								<span class="font-family-mono text-white">{project.title}</span>
								<span class="text-white/60"> — {project.shortDescription}</span>
							</a>
						</li>
					))}
				</ul>
			</aside>
		)}

		{allPosts.length > 0 && (
			<aside class="prose prose-invert mx-auto mt-10 pt-8 border-t border-white/10">
				<h2 class="text-xl font-light text-white !mt-0">More articles</h2>
				<ul class="list-none pl-0">
					{allPosts.map((other) => (
						<li class="pl-0">
							<a href={`/blog/${other.id}`} class="no-underline hover:text-accent">
								<span class="text-white">{other.data.title}</span>
								<span class="text-white/60"> — {other.data.description}</span>
							</a>
						</li>
					))}
				</ul>
			</aside>
		)}
	</article>
</AppWrapper>
