---
import { getCollection } from "astro:content";
import AppWrapper from "../building-blocks/AppWrapper.astro";
import BlogCardWithImage from "../components/BlogCardWithImage.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Segment from "../components/Segment.astro";
import { getProjectsWithVersions } from "../config/projects";
import { siteConfig } from "../config/site";

const projects = await getProjectsWithVersions();

// Get the last 3 blog posts
const posts = await getCollection("blog");
const sortedPosts = posts.sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = sortedPosts.slice(0, 3);
---

<AppWrapper
	title="Kool Codez | React libraries, TypeScript UI components, frontend engineering"
	description={siteConfig.description}
>
	<!-- Hero Section -->
	<section class="text-center max-w-4xl mx-auto">
		<img
			src="/kool-codez-logo.svg"
			alt={siteConfig.title}
			class="max-w-md mx-auto"
		/>
		<p class="text-xl font-light mx-auto max-w-xl pt-6 text-white/70">
			A decade of frontend engineering, crafting fast, polished UIs built
			on a core of clean, stable, and genuinely maintainable code.
		</p>
	</section>

	<!-- Expertise Section -->
	<section class="py-8 md:py-12">
		<SectionHeading>The approach</SectionHeading>
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-18 md:px-6">
			<Segment>
				<div slot="title">One truth</div>
				<div slot="description">
					100% TypeScript built on a single source of truth for types.
					Frontend to backend consistency, avoiding entire classes of
					integration bugs.
				</div>
			</Segment>
			<Segment>
				<div slot="title">Light touch</div>
				<div slot="description">
					Design that is minimal, clean, and slick. The result is a
					lightweight and intuitive UI that keeps the user focused and
					the experience seamless.
				</div>
			</Segment>
			<Segment>
				<div slot="title">True balance</div>
				<div slot="description">
					Performance without compromise on code health. Every
					optimization weighed against long-term maintainability.
				</div>
			</Segment>
		</div>
	</section>

	<!-- Projects Section -->
	<section class="py-8 md:py-12">
		<SectionHeading>Projects</SectionHeading>
		<p class="text-center font-light text-white/70 max-w-lg mx-auto -mt-10 mb-14">
			Open source libraries, published on npm with live documentation.
		</p>
		<div
			class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 md:px-6"
		>
			{projects.filter(p => ['react-socket', 'react-searchable-dropdown', 'swipe-bar'].includes(p.title)).map((project) => (
				<ProjectCard
					title={project.title}
					description={project.shortDescription}
					href={project.href}
					status={project.status}
					logo={project.logo}
				/>
			))}
		</div>
		<div class="text-center mt-10">
			<a
				href="/projects"
				class="text-sm text-white/40 hover:text-accent transition-colors duration-200"
			>
				View all projects &rarr;
			</a>
		</div>
	</section>

	<!-- Blog Section -->
	<section class="py-8 md:py-12">
		<SectionHeading>Latest articles</SectionHeading>
		<div
			class="grid gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3 md:px-12"
		>
			{
				recentPosts.map((post) => (
					<BlogCardWithImage
						slug={post.id}
						date={post.data.pubDate}
						heroImage={post.data.heroImage}
						title={post.data.title}
					>
						<div slot="title">{post.data.title}</div>
						<div slot="description">{post.data.description}</div>
					</BlogCardWithImage>
				))
			}
		</div>
		<div class="text-center mt-10">
			<a
				href="/blog"
				class="text-sm text-white/40 hover:text-accent transition-colors duration-200"
			>
				View all articles &rarr;
			</a>
		</div>
	</section>
</AppWrapper>
